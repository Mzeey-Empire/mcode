# Runtime paths
# MCODE_DATA_DIR=~/.mcode-dev     # Root data dir (~/.mcode in prod, ~/.mcode-dev in dev)
# MCODE_DB_PATH=                  # Override DB path (default: $MCODE_DATA_DIR/mcode.db)

# Server
# MCODE_PORT=19400                # HTTP/WS server port (increments on collision, up to 19409)
# MCODE_HOST=127.0.0.1            # Server bind host
# MCODE_AUTH_TOKEN=               # Empty string bypasses auth (all environments)
# MCODE_CODEX_TRACE=1            # Codex: log each notification + mapped AgentEvent summary (dev only)

# Tool paths
# MCODE_CLAUDE_PATH=claude        # Claude CLI binary (must be in PATH if unset)
# MCODE_GIT_PATH=git              # git binary (must be in PATH if unset)

# App
# MCODE_VERSION=0.0.1             # Reported version string
# SNAPSHOT_MAX_AGE_DAYS=30        # Days before turn snapshot cleanup

# Build
# SKIP_ELECTRON_REBUILD=1         # Set to skip Electron ABI rebuild in postinstall
