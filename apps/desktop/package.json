{
  "name": "mcode-desktop",
  "version": "0.5.0",
  "description": "Mcode AI agent orchestration desktop app",
  "author": {
    "name": "Mzeey Empire",
    "email": "cjnwob@gmail.com"
  },
  "homepage": "https://github.com/Mzeey-Emipre/mcode",
  "main": "dist/main/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "bun scripts/dev-electron.mjs",
    "build": "bun scripts/build-main.mjs",
    "prod": "NODE_ENV=production bun run build && NODE_ENV=production npx electron .",
    "typecheck": "tsc --noEmit",
    "rebuild": "electron-rebuild -f",
    "dist": "bun run build && bun scripts/generate-snapshot.mjs && electron-builder --publish never",
    "dist:no-snapshot": "bun run build && electron-builder --publish never",
    "test": "vitest run"
  },
  "dependencies": {
    "@electron/rebuild": "^3.7.1",
    "@mcode/contracts": "workspace:*",
    "@mcode/shared": "workspace:*",
    "better-sqlite3": "^12.0.0",
    "electron-updater": "^6.8.3",
    "node-pty": "^1.0.0",
    "uuid": "^11.1.0",
    "which": "^5.0.0"
  },
  "devDependencies": {
    "@electron/fuses": "^2.1.1",
    "@types/uuid": "^10.0.0",
    "@types/which": "^3.0.4",
    "@vitest/coverage-v8": "^4.1.0",
    "electron": "35.7.5",
    "electron-builder": "^25.1.0",
    "electron-mksnapshot": "35.7.5",
    "esbuild": "^0.27.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.0"
  },
  "build": {
    "appId": "com.mzeey.mcode",
    "productName": "Mcode",
    "afterPack": "./scripts/after-pack.mjs",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json",
      "node_modules/better-sqlite3/**/*",
      "node_modules/node-pty/**/*"
    ],
    "asarUnpack": [
      "dist/server/**",
      "node_modules/better-sqlite3/**",
      "node_modules/node-pty/**"
    ],
    "publish": {
      "provider": "github",
      "owner": "mzeey-empire",
      "repo": "mcode"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development"
    }
  }
}
