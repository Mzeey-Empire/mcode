{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "test": {},
    "typecheck": {
      "outputs": ["node_modules/.cache/tsbuildinfo"]
    },
    "lint": {}
  }
}
